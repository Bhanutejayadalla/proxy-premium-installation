rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Check that only follower/following array fields are being modified
    function onlyFollowFields() {
      let allowed = ['followers', 'following',
                     'followers_formal', 'followers_casual',
                     'following_formal', 'following_casual'].toSet();
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
    }

    // ── Users ─────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      // Owner can update anything; other signed-in users can only
      // modify follower / following arrays (for follow/unfollow).
      allow update: if isOwner(userId)
                    || (isSignedIn() && onlyFollowFields());
      allow delete: if isOwner(userId);
    }

    // ── Posts ─────────────────────────────────────────────────
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.author_id == request.auth.uid;
      allow update: if isSignedIn()
                    && resource.data.author_id == request.auth.uid;
      allow delete: if isSignedIn()
                    && resource.data.author_id == request.auth.uid;
    }

    // ── Stories ───────────────────────────────────────────────
    match /stories/{storyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.author_id == request.auth.uid;
      allow delete: if isSignedIn()
                    && resource.data.author_id == request.auth.uid;
    }

    // ── Reels ─────────────────────────────────────────────────
    match /reels/{reelId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.author_id == request.auth.uid;
      allow update: if isSignedIn();   // view counts, likes
      allow delete: if isSignedIn()
                    && resource.data.author_id == request.auth.uid;
    }

    // ── Chats & Messages ──────────────────────────────────────
    match /chats/{chatId} {
      allow read, create, update, delete: if isSignedIn();

      match /messages/{messageId} {
        allow read, create, delete: if isSignedIn();
      }
    }

    // ── Group Chats & Messages ────────────────────────────────
    match /group_chats/{groupId} {
      allow read, create, update, delete: if isSignedIn();

      match /messages/{messageId} {
        allow read, create, delete: if isSignedIn();
      }
    }

    // ── Notifications ─────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    // ── Jobs ──────────────────────────────────────────────────
    match /jobs/{jobId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.author_id == request.auth.uid;
      allow update, delete: if isSignedIn()
                            && resource.data.author_id == request.auth.uid;
    }

    // ── Connections ───────────────────────────────────────────
    match /connections/{connId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.from == request.auth.uid;
      allow update: if isSignedIn()
                    && (resource.data.from == request.auth.uid
                        || resource.data.to == request.auth.uid);
      allow delete: if isSignedIn()
                    && (resource.data.from == request.auth.uid
                        || resource.data.to == request.auth.uid);
    }
  }
}
